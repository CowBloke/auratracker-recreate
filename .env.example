# ── Database ────────────────────────────────────────────────────────────────
# Dev default is SQLite (zero-setup). For production, point DATABASE_URL at
# Postgres and run `pnpm --filter @aura/db use-postgres` to switch the Prisma
# provider, then migrate. DB access is isolated in packages/db so nothing else
# changes.
DATABASE_URL="file:./dev.db"
DATABASE_PROVIDER="sqlite"

# ── API server ───────────────────────────────────────────────────────────────
API_PORT=4000
NODE_ENV=development

# Comma-separated list of allowed web origins for CORS + sockets.
WEB_ORIGIN="http://localhost:5173"

# Secret used to sign/seal session cookies. MUST be >=32 chars and random in prod.
SESSION_SECRET="dev-only-change-me-please-32chars-minimum-secret"

# Session lifetime (days) and rolling refresh.
SESSION_TTL_DAYS=30

# ── Web app (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL="http://localhost:4000"
