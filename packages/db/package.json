{
  "name": "@aura/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "push": "dotenv -e ../../.env -- prisma db push --skip-generate",
    "migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "reset": "dotenv -e ../../.env -- prisma migrate reset --force",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "use-postgres": "node scripts/use-postgres.mjs",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "@aura/config": "workspace:*",
    "@aura/contracts": "workspace:*",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
